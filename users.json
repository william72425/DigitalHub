// ============================================
// START COMMAND
// ============================================
bot.start(async (ctx) => {
    const userId = ctx.from.id;
    const username = ctx.from.username;
    const firstName = ctx.from.first_name;
    
    // Save user to persistent storage
    if (!users.has(userId)) {
        users.set(userId, { 
            username: username, 
            firstName: firstName, 
            joined: new Date().toISOString() 
        });
        saveUsers(users);
        console.log(`✅ New user saved: ${userId} (@${username}) - Total: ${users.size}`);
    }
    
    if (userId === ADMIN_ID) {
        await ctx.reply(
            `🔧 <b>Admin Panel</b>\n\nWelcome back, ${firstName}!\nUsers in database: ${users.size}\nOrders: ${pendingOrders.size}`,
            { parse_mode: 'HTML', ...adminMenu }
        );
    } else {
        await ctx.reply(
            `🎉 <b>Welcome to Digital Hub Store!</b>\n\nHello ${firstName}!\n\nUse the buttons below.`,
            { parse_mode: 'HTML', ...mainMenu }
        );
    }
});

