bot.action('announce_all', async (ctx) => {
    if (ctx.from.id !== ADMIN_ID) return;
    await ctx.answerCbQuery();
    
    if (users.size === 0) {
        await ctx.editMessageText('❌ No users in database. Users appear when they send /start.');
